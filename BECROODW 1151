using System;

class Program
{
    static void Main(string[] args)
    {
        int N = int.Parse(Console.ReadLine());

        int a = 0, b = 1;

        for (int i = 0; i < N; i++)
        {
            if (i == N - 1)
                Console.Write(a);
            else
                Console.Write(a + " ");

            int proximo = a + b;
            a = b;
            b = proximo;
        }

        Console.WriteLine();
    }
}
