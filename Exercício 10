using System;

class Exercicio10
{
    static void Main()
    {
        int numero = LerInteiro("Digite um número inteiro positivo: ");

        if (numero < 2)
        {
            Console.WriteLine("Não é primo.");
            return;
        }

        bool primo = true;

        for (int i = 2; i <= Math.Sqrt(numero); i++)
        {
            if (numero % i == 0)
            {
                primo = false;
                break;
            }
        }

        if (primo)
            Console.WriteLine("É número primo.");
        else
            Console.WriteLine("Não é número primo.");
    }

    static int LerInteiro(string msg)
    {
        int valor;
        while (true)
        {
            Console.Write(msg);
            if (int.TryParse(Console.ReadLine(), out valor))
                return valor;
            Console.WriteLine("Valor inválido.");
        }
    }
}
