using System;

class Exercicio17
{
    static void Main()
    {
        int n = LerInteiro("Digite um número positivo: ");

        if (n < 1)
        {
            Console.WriteLine("Número inválido.");
            return;
        }

        int soma = 0;

        for (int i = 2; i <= n; i += 2)
            soma += i;

        Console.WriteLine($"Soma dos pares até {n} = {soma}");
    }

    static int LerInteiro(string msg)
    {
        int valor;
        while (true)
        {
            Console.Write(msg);
            if (int.TryParse(Console.ReadLine(), out valor))
                return valor;

            Console.WriteLine("Valor inválido.");
        }
    }
}
