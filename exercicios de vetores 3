using System;

class Program
{
    static void Main(string[] args)
    {
        int[] vetor = new int[8];

        Console.WriteLine("Digite 8 números inteiros para o vetor:");

        // Leitura dos valores
        for (int i = 0; i < 8; i++)
        {
            Console.Write($"Número {i + 1}: ");
            vetor[i] = int.Parse(Console.ReadLine());
        }

        // Leitura do valor a ser pesquisado
        Console.Write("Digite um número para buscar no vetor: ");
        int valor = int.Parse(Console.ReadLine());

        // Verifica se o valor está no vetor
        bool encontrado = false;
        for (int i = 0; i < 8; i++)
        {
            if (vetor[i] == valor)
            {
                Console.WriteLine($"O número {valor} está na posição {i} do vetor.");
                encontrado = true;
                break; // Para a busca ao encontrar o valor
            }
        }

        if (!encontrado)
        {
            Console.WriteLine("O número não se encontra no vetor.");
        }
    }
}
