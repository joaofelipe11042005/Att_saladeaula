using System;

class Exercicio9
{
    static void Main()
    {
        int numero = LerInteiro("Digite um número inteiro (0 a 20): ");

        if (numero < 0 || numero > 20)
        {
            Console.WriteLine("Número fora do limite permitido.");
            return;
        }

        long fatorial = 1;

        for (int i = 1; i <= numero; i++)
            fatorial *= i;

        Console.WriteLine($"Fatorial de {numero} = {fatorial}");
    }

    static int LerInteiro(string msg)
    {
        int valor;
        while (true)
        {
            Console.Write(msg);
            if (int.TryParse(Console.ReadLine(), out valor))
                return valor;
            Console.WriteLine("Valor inválido.");
        }
    }
}
